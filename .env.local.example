# Copy this file to .env.local and fill in real values.
# .env.local is git-ignored; never commit real keys.

# Anthropic API key. Get one from https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: override default models (defaults chosen for cost + speed).
# ANTHROPIC_JUDGE_MODEL=claude-sonnet-4-6
# ANTHROPIC_EXTRACTOR_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_RAW_MODEL=claude-sonnet-4-6

# Human Delta API key. Powers the verified-column retrieval.
# Get one at the Human Delta workshop / dashboard.
HUMANDELTA_API_KEY=hd_live_...

# Optional: override the HD API base URL (defaults to https://api.humandelta.ai)
# HUMANDELTA_BASE_URL=https://api.humandelta.ai
